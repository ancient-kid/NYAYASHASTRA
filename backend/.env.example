# NyayaShastra Backend Configuration - example (do NOT commit sensitive keys)

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://localhost:8081,http://localhost:8082

# Database (SQLite for local development)
DATABASE_URL=sqlite:///./nyayashastra.db

# Vector Database
CHROMA_PERSIST_DIR=./chroma_db
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Domain guardrail mode: soft | strict | llm | none
DOMAIN_GUARDRAIL_MODE=llm

# Groq API (primary LLM) — set in your environment or here locally (DO NOT commit)
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# OpenAI (optional fallback)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4-turbo-preview

# Hugging Face token (optional, speeds model downloads)
HF_TOKEN=hf_xxx
